# ============================================
# AI TRADING PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ============================================

# Anthropic (Required - get from https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NexusTrader
ADMIN_PASSWORD=your_secure_admin_password

# Polygon.io (Free tier available - https://polygon.io)
POLYGON_API_KEY=your_polygon_api_key_here

# CoinGecko (Free tier available - https://coingecko.com/api)
COINGECKO_API_KEY=your_coingecko_api_key_here

# Alpha Vantage (Free tier - https://alphavantage.co)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# FRED API (Free - https://fred.stlouisfed.org/docs/api)
FRED_API_KEY=your_fred_api_key_here

# NewsAPI (Free tier - https://newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# Binance (No auth needed for public data)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Bloomberg (Enterprise - optional)
BLOOMBERG_API_KEY=

# Demo Mode Settings
NEXT_PUBLIC_DEMO_STARTING_BALANCE=1000
NEXT_PUBLIC_DEMO_RESET_DAYS=30

# Platform Settings
NEXT_PUBLIC_PLATFORM_FEE_PERCENT=0.1
NEXT_PUBLIC_DEFAULT_SLIPPAGE=0.05
